# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# mise auto-loads `.env` thanks to the `_.file = ".env"` line in mise.toml.

# ─────────── Databricks Free Edition ───────────
# Get this from the URL of your Free Edition workspace, e.g.:
#   https://dbc-1234abcd-5678.cloud.databricks.com
# (No trailing slash.)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Name of the local auth profile that `databricks auth login` will write to
# ~/.databrickscfg. DEFAULT is fine; change only if you juggle multiple workspaces.
DATABRICKS_PROFILE=DEFAULT

# Workspace path the `mise run db:import` task will sync notebooks into.
# Replace with your own user folder (use your login email).
DATABRICKS_NOTEBOOK_DEST=/Workspace/Users/you@example.com/databricks-fde-study

# Default catalog + schema the labs write tables into. These are the Free Edition
# defaults; change if your workspace is set up differently.
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=default
